# =============================================================================
# CyberShield — Environment Variable Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in ALL required values (marked with REQUIRED)
#   3. NEVER commit .env to version control
#   4. See docs/developer_guide.md for full configuration reference
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
# Application environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Output format: json | console (use json in production)
LOG_FORMAT=console

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
# Secret key for request signing and session tokens (REQUIRED in production)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-real-secret-key

# API bearer token for service-to-service auth (REQUIRED in production)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=dev-api-key-change-in-production

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# SQLite for development (default), PostgreSQL for staging/production
# SQLite: sqlite+aiosqlite:///./data/cybershield.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/cybershield
DATABASE_URL=sqlite+aiosqlite:///./data/cybershield.db

# Maximum DB connections in pool (PostgreSQL only)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# LLM (Anthropic Claude) — Module: llm
# ---------------------------------------------------------------------------
# REQUIRED for Week 3+ LLM enrichment module
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use (see docs/module_contracts.md for version pinning)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-call timeout in seconds (fail-open after this)
LLM_TIMEOUT_SECONDS=2

# Maximum USD cost per alert enrichment call
LLM_MAX_COST_PER_CALL_USD=0.01

# ---------------------------------------------------------------------------
# ANOMALY DETECTION — Module: detection
# ---------------------------------------------------------------------------
# Isolation Forest contamination rate (fraction of expected anomalies in normal data)
ISOLATION_FOREST_CONTAMINATION=0.01

# Number of estimators (trees) in the forest
ISOLATION_FOREST_N_ESTIMATORS=100

# Reproducibility seed
ISOLATION_FOREST_RANDOM_STATE=42

# Alert threshold: anomaly score above this triggers an alert
ANOMALY_SCORE_THRESHOLD=0.5

# ---------------------------------------------------------------------------
# AUDIT & METRICS — Module: audit
# ---------------------------------------------------------------------------
# Maximum number of audit log records to retain in rolling window
AUDIT_LOG_MAX_RECORDS=10000

# Metrics computation interval in seconds
METRICS_INTERVAL_SECONDS=3600

# ---------------------------------------------------------------------------
# DATA PATHS
# ---------------------------------------------------------------------------
# Root directory for all data artifacts
DATA_DIR=./data

# Directory for trained model artifacts
MODELS_DIR=./models

# Directory for reports and evaluations
REPORTS_DIR=./reports

# ---------------------------------------------------------------------------
# CORS (for dashboard / frontend integration)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://dashboard.cybershield.local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# FEATURE FLAGS (enable/disable modules as they are implemented)
# ---------------------------------------------------------------------------
FEATURE_INGESTION_ENABLED=false
FEATURE_NORMALIZATION_ENABLED=false
FEATURE_DETECTION_ENABLED=false
FEATURE_MITRE_ENABLED=false
FEATURE_GRAPH_ENABLED=false
FEATURE_LLM_ENABLED=false
FEATURE_RESPONSE_ENABLED=false
FEATURE_AUDIT_ENABLED=false
FEATURE_DASHBOARD_ENABLED=false

# ---------------------------------------------------------------------------
# MODULE 1.2: DIGITAL TWIN FOUNDATION
# ---------------------------------------------------------------------------
# Enable the Digital Twin environment (requires Docker containers running)
FEATURE_DIGITAL_TWIN_ENABLED=true

# --- Network (must match docker/docker-compose.yml static IPs) ---
DT_HOSPITAL_SERVER_IP=172.20.1.10
DT_HOSPITAL_SERVER_PORT=9002
DT_DOMAIN_CONTROLLER_IP=172.20.1.20
DT_DOMAIN_CONTROLLER_PORT=9001
DT_OT_NODE_IP=172.20.2.10
DT_OT_NODE_PORT=9003
DT_ATTACKER_IP=172.20.3.10

# --- Log Storage ---
DT_LOG_BASE_DIR=./data/digital_twin

# --- Generation Rates ---
# false = real-time baseline collection
# true  = accelerated (7 days in ~10 minutes for CI)
DT_ACCELERATED_MODE=false
DT_ACCELERATION_FACTOR=1440

# --- Health Checks ---
DT_HEALTH_CHECK_TIMEOUT_SECONDS=5
DT_HEALTH_CHECK_RETRY_COUNT=3
