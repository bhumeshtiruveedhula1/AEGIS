# =============================================================================
# CyberShield — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.env
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Environment Variables (NEVER commit secrets)
# ---------------------------------------------------------------------------
.env
.env.local
.env.staging
.env.production
*.secret

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.ropeproject/

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
reports/coverage/
.tox/
.nox/
*.cover
nosetests.xml
coverage.xml

# ---------------------------------------------------------------------------
# Type Checking
# ---------------------------------------------------------------------------
.mypy_cache/
.pytype/
.pyre/

# ---------------------------------------------------------------------------
# Data & Model Artifacts (large binary files)
# ---------------------------------------------------------------------------
data/raw/
data/normalized/
*.jsonl
!data/attack_reference/*.json
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx

# ---------------------------------------------------------------------------
# Reports (generated, not source-controlled)
# ---------------------------------------------------------------------------
reports/*.json
reports/*.html
reports/*.pdf
!reports/.gitkeep

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
*.out

# ---------------------------------------------------------------------------
# Jupyter Notebooks (outputs stripped separately, keep .ipynb sources)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---------------------------------------------------------------------------
# OS-specific
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# Temporary / scratch files
# ---------------------------------------------------------------------------
tmp/
scratch/
*.tmp
*.bak
*.orig
