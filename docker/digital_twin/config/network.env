# =============================================================================
# Digital Twin Network Configuration
# Shared across all containers via docker-compose env_file
# =============================================================================

# --- Management Segment (172.20.0.0/24) ---
DT_API_IP=172.20.0.10
DT_API_PORT=8000

# --- IT Segment (172.20.1.0/24) ---
DT_HOSPITAL_SERVER_IP=172.20.1.10
DT_HOSPITAL_SERVER_PORT=9002
DT_HOSPITAL_SERVER_HOSTNAME=hospital-server-01

DT_DOMAIN_CONTROLLER_IP=172.20.1.20
DT_DOMAIN_CONTROLLER_PORT=9001
DT_DOMAIN_CONTROLLER_HOSTNAME=dc-01

DT_DOMAIN_NAME=CORP.HOSPITAL.LOCAL
DT_DC_IP=172.20.1.20

# --- OT Segment (172.20.2.0/24) ---
DT_OT_NODE_IP=172.20.2.10
DT_OT_NODE_PORT=9003
DT_OT_NODE_HOSTNAME=plc-01
DT_SUPERVISORY_HOST=192.168.1.100

# --- Attacker Segment (172.20.3.0/24) ---
DT_ATTACKER_IP=172.20.3.10
DT_ATTACKER_HOSTNAME=attacker-kali

# --- Attack targets (for future modules) ---
DT_ATTACK_TARGET_IT_IP=172.20.1.10
DT_ATTACK_TARGET_DC_IP=172.20.1.20
DT_ATTACK_TARGET_OT_IP=172.20.2.10

# --- Health Check ---
DT_HEALTH_CHECK_TIMEOUT_SECONDS=5
DT_HEALTH_CHECK_RETRY_COUNT=3
