# =============================================================================
# Digital Twin Event Generation Rates
# Tune these to control baseline telemetry volume
# =============================================================================

# --- Mode ---
# false = real-time (use for actual 7-day baseline collection)
# true  = accelerated (use for CI, testing, demo baseline generation)
DT_ACCELERATED_MODE=false
DT_ACCELERATION_FACTOR=1440

# --- Hospital Server rates (events per hour, real-time) ---
DT_PROCESS_CREATES_PER_HOUR=75
DT_NETWORK_CONNECTS_PER_HOUR=150
DT_FILE_EVENTS_PER_HOUR=50
DT_AUTH_EVENTS_PER_HOUR=20

# --- Domain Controller rates (events per hour) ---
DT_DC_SUCCESSFUL_LOGINS_PER_HOUR=12
DT_DC_FAILED_LOGINS_PER_HOUR=5
DT_DC_PRIVILEGE_EVENTS_PER_HOUR=3
DT_DC_USER_MGMT_PER_HOUR=2
DT_DC_KERBEROS_PER_HOUR=30

# --- OT Node timing (in seconds, real-time) ---
DT_OT_READ_INTERVAL_SECONDS=5
DT_OT_WRITE_INTERVAL_SECONDS=60
DT_OT_HEARTBEAT_INTERVAL_SECONDS=30

# --- OT Normal register ranges ---
DT_OT_READ_REG_START=10
DT_OT_READ_REG_END=20
DT_OT_WRITE_REG_START=30
DT_OT_WRITE_REG_END=40

# --- Attacker ---
DT_ATTACKER_KEEPALIVE_INTERVAL=60

# --- Writer ---
DT_BUFFER_SIZE=50

# --- Reproducibility ---
# Each container uses a different seed to avoid correlated randomness
# Hospital Server: 42, Domain Controller: 43, OT Node: 44
DT_RANDOM_SEED=42
